    "Full Disk Access Message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Due to system security restrictions, App Store downloads do not have the right to read files outside of the app directly. So we need your authorization, but we won't collect any information from you!\nNote: Without authorization, you will not be able to use right click upload, share upload, command line upload and other functions"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "由于系统的安全限制，App Store 下载的软件无权直接读取应用外的文件。所以我们需要您的授权，但我们不会收集你的任何信息！\n\n注：若不授权，将无法使用右键上传、分享上传、命令行上传等功能"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "由於系統的安全限制，App Store下載的軟件無權直接讀取應用外的檔案。所以我們需要您的授權，但我們不會收集你的任何資訊！\n\n注：若不授權，將無法使用右鍵上傳、分享上傳、命令列上傳等功能"
          }
        }
      }
    },
    "General": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通用"
          }
        },
