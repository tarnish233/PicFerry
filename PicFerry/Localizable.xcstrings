    "Save Key Tips": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Supports {year} {month} {day} {hour} {minute} {second} {since_second} {since_millisecond} {random} {filename} {.suffix} {suffix} {mimetype} and etc. For example, the uploaded file is GitPic.jpg, set to \"GitPic/{filename}{.suffix}\", it will be saved as: GitPic/GitPic.jpg."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "支持 {year} {month} {day} {hour} {minute} {second} {since_second} {since_millisecond} {random} {filename} {.suffix} {suffix} {mimetype} 等变量。比如: 上传的图片为 GitPic.jpg, 设定为 “GitPic/{filename}{.suffix}”, 则会保存到 “GitPic/GitPic.jpg”。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "支持 {year} {month} {day} {hour} {minute} {second} {since_second} {since_millisecond} {random} {filename} {.suffix} {suffix} {mimetype} 等變量。比如: 上傳的圖片為 GitPic.jpg, 設定為 “GitPic/{filename}{.suffix}”, 則會保存到 “GitPic/GitPic.jpg”。"
          }
        }
      }
